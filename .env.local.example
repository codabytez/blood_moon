# Copy this file to .env.local and fill in your Convex deployment URL
# Run: npx convex dev — it will create .env.local automatically
VITE_CONVEX_URL=https://your-project.convex.cloud

VITE_CONVEX_SITE_URL=https://your-project.convex.site

CONVEX_DEPLOYMENT=dev:your-project # team: your-team, project: your-project
